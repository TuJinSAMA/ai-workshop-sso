generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id              String   @id @default(uuid())
  email           String   @unique
  emailVerified   Boolean  @default(false)
  passwordHash    String?
  passwordAlgo    String   @default("argon2id")
  legacySalt      String?

  displayName     String?
  avatarUrl       String?
  status          UserStatus @default(ACTIVE)

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sessions                 Session[]
  identities               Identity[]
  loginAttempts            LoginAttempt[]
  passwordResetTokens      PasswordResetToken[]
  emailVerificationTokens  EmailVerificationToken[]

  @@index([email])
}

model Identity {
  id          String   @id @default(uuid())
  userId      String
  provider    String
  providerId  String

  user        User @relation(fields: [userId], references: [id])

  @@unique([provider, providerId])
}

model Session {
  id              String   @id @default(uuid())
  userId          String

  userAgent       String?
  ipAddress       String?

  expiresAt       DateTime
  revokedAt       DateTime?
  lastActiveAt    DateTime @default(now())
  createdAt       DateTime @default(now())

  user            User @relation(fields: [userId], references: [id])

  @@index([userId])
}

// Generic storage for all oidc-provider internal models
// (AccessToken / AuthorizationCode / RefreshToken / Grant / Session /
//  Interaction / ReplayDetection / IdToken / DeviceCode / ClientCredentials /
//  BackchannelAuthenticationRequest / PushedAuthorizationRequest).
// `id` is `<model>:<uid>` so we can store every model in one table.
// Reuse-detection (M2) queries by model='RefreshToken' + consumed=true.
model OidcModel {
  id        String    @id
  model     String
  payload   Json
  expiresAt DateTime?
  grantId   String?
  userCode  String?
  uid       String?
  consumed  Boolean   @default(false)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([model])
  @@index([grantId])
  @@index([uid])
  @@index([userCode])
  @@index([expiresAt])
}

model OAuthClient {
  clientId               String   @id
  clientSecretHash       String
  name                   String
  redirectUris           String[]
  postLogoutRedirectUris String[]
  allowedScopes          String[]
  createdAt              DateTime @default(now())
}

model SigningKey {
  kid             String   @id
  algorithm       String
  publicKeyPem    String
  privateKeyPem   String
  status          KeyStatus
  createdAt       DateTime @default(now())
  retiredAt       DateTime?
}

// One-time token for password reset (spec §12).
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique   // SHA-256 of the raw token, hex-encoded
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

// One-time token for email verification (spec §10).
model EmailVerificationToken {
  id        String   @id @default(uuid())
  userId    String
  email     String   // The email address to verify (could be new email for change-email flow)
  tokenHash String   @unique   // SHA-256 of the raw token, hex-encoded
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([expiresAt])
}

model LoginAttempt {
  id              String   @id @default(uuid())
  userId          String?
  email           String
  ipAddress       String
  success         Boolean
  failReason      String?
  createdAt       DateTime @default(now())

  user            User? @relation(fields: [userId], references: [id])

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
}

model AuditLog {
  id              String   @id @default(uuid())
  userId          String?
  event           String
  ipAddress       String?
  userAgent       String?
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

enum UserStatus {
  ACTIVE
  DISABLED
  DELETED
}

enum KeyStatus {
  ACTIVE
  RETIRED
}
