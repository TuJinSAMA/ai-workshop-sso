# Caddy auto-HTTPS for the SSO service.
# Caddy obtains and renews a Let's Encrypt certificate automatically as long
# as auth.aiprd.club resolves to this server and ports 80/443 are open.

{
    # Replace with your real email for Let's Encrypt expiry notifications.
    email admin@aiprd.club
    # Uncomment for staging certs while debugging issuance:
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

auth.aiprd.club {
    encode zstd gzip

    # Strict transport security (spec Section 10).
    header {
        Strict-Transport-Security "max-age=63072000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        # CSP is intentionally conservative; loosen only as login UI requires.
        Content-Security-Policy "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; frame-ancestors 'none'"
        -Server
    }

    reverse_proxy app:3000 {
        header_up X-Forwarded-Proto {scheme}
        header_up X-Forwarded-Host {host}
        header_up X-Real-IP {remote_host}
    }
}
