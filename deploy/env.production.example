# 复制为 /opt/ai-workshop-sso/.env.production，填写真实值后 chmod 600

NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# OIDC Issuer（对外暴露的 SSO 地址）
ISSUER_URL=https://auth.aiprd.club

# shared-infra 网络内使用容器名；密码建议 openssl rand -hex 24（避免 URL 特殊字符）
DATABASE_URL=postgresql://sso_user:PASSWORD@shared-postgres:5432/ai_workshop_sso?schema=public
REDIS_URL=redis://shared-redis:6379

# Cookie 加密：openssl rand -hex 32
COOKIE_SECRET=
SSO_COOKIE_NAME=aiprd_sso
SSO_COOKIE_DOMAIN=.aiprd.club
SSO_COOKIE_TTL_DAYS=30
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CODE_TTL_MINUTES=5

# JWKS 加密：openssl rand -hex 32
JWKS_ENCRYPTION_KEY=
JWKS_ROTATION_MONTHS=6

# 邮件（开发/测试用 console，生产改 resend）
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=noreply@aiprd.club

# 内部 API 鉴权（供其他服务调用 SSO 内部接口）：openssl rand -hex 32
INTERNAL_API_TOKEN=
