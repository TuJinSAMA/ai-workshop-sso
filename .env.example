# ---------- Service ----------
NODE_ENV=development
ISSUER_URL=http://localhost:3000
PORT=3000

# ---------- Database ----------
# Local development default; change to your real Postgres URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workshop_sso?schema=public

# ---------- Cookie ----------
# 32+ random bytes (e.g. `openssl rand -hex 32`)
COOKIE_SECRET=replace_me_with_random_32_bytes_hex
SSO_COOKIE_NAME=aiprd_sso
# In production: .aiprd.club ; in local dev leave empty so it defaults to host
SSO_COOKIE_DOMAIN=
SSO_COOKIE_TTL_DAYS=30

# ---------- Token ----------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CODE_TTL_MINUTES=5

# ---------- JWKS ----------
# Path to encrypted JWKS file, or leave empty to load from DB SigningKey table
SIGNING_KEY_PATH=
JWKS_ROTATION_MONTHS=6

# ---------- Email ----------
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=noreply@aiprd.club

# ---------- Rate limit (Upstash / Redis) ----------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ---------- Internal API auth ----------
# 32+ random bytes; required header X-Internal-Token for /api/internal/*
INTERNAL_API_TOKEN=replace_me_with_random_32_bytes_hex
