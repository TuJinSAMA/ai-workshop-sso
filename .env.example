# ---------- Service ----------
NODE_ENV=production
ISSUER_URL=https://auth.aiprd.club
PORT=3000

# ---------- Database ----------
# Local dev:        postgresql://postgres:postgres@localhost:5432/ai_workshop_sso
# Aliyun (Docker):  postgresql://<user>:<pass>@<host>:5432/ai_workshop_sso
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_workshop_sso?schema=public

# ---------- Redis (rate limit, OIDC state, future caching) ----------
# Local dev: redis://127.0.0.1:6379
# Aliyun:    redis://<host>:6379/0  (or redis://:password@host:6379/0)
REDIS_URL=redis://127.0.0.1:6379

# ---------- Cookies / SSO ----------
# 32+ random bytes: `openssl rand -hex 32`
COOKIE_SECRET=replace_me_with_random_32_bytes_hex
SSO_COOKIE_NAME=aiprd_sso
# In production: .aiprd.club ; in local dev leave empty so it defaults to host
SSO_COOKIE_DOMAIN=
SSO_COOKIE_TTL_DAYS=30

# ---------- Token ----------
ACCESS_TOKEN_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=30
AUTH_CODE_TTL_MINUTES=5

# ---------- JWKS ----------
# 32 random bytes hex; used to AES-256-GCM-encrypt private keys at rest in DB.
# If empty, derived from COOKIE_SECRET via scrypt (OK for dev, set explicitly in prod).
JWKS_ENCRYPTION_KEY=
JWKS_ROTATION_MONTHS=6

# ---------- Email ----------
# "console" (Phase 0 default — just logs, does NOT send) | "resend"
EMAIL_PROVIDER=console
RESEND_API_KEY=
EMAIL_FROM=noreply@aiprd.club

# ---------- Internal API auth ----------
# Required header X-Internal-Token for /api/internal/*
INTERNAL_API_TOKEN=replace_me_with_random_32_bytes_hex
